---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="PeptideBay privacy policy - how we handle your data.">

<section class="py-12 lg:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <header class="mb-12">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-industrial-100 mb-4">
        <span class="text-chem-green">Privacy</span> Policy
      </h1>
      <p class="text-industrial-400">
        Last updated: February 2026
      </p>
    </header>

    <div class="space-y-8">
      
      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Information We Collect
        </h2>
        <p class="text-industrial-300 leading-relaxed mb-4">
          PeptideBay is designed with privacy in mind. We collect minimal information:
        </p>
        <ul class="space-y-2 text-industrial-400">
          <li class="flex items-start gap-2">
            <span class="text-chem-green mt-1">•</span>
            <span><strong class="text-industrial-200">Usage Analytics:</strong> Anonymous page view statistics to improve our content</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-chem-green mt-1">•</span>
            <span><strong class="text-industrial-200">Search Queries:</strong> Search terms are processed locally and not stored</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-chem-green mt-1">•</span>
            <span><strong class="text-industrial-200">Contact Information:</strong> If you email us, we retain your message for support purposes</span>
          </li>
        </ul>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          How We Use Information
        </h2>
        <p class="text-industrial-300 leading-relaxed">
          Any information collected is used solely to:
        </p>
        <ul class="space-y-2 text-industrial-400 mt-4">
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Improve website content and user experience
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Respond to inquiries and provide support
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Analyze traffic patterns (anonymized)
          </li>
        </ul>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Cookies & Tracking
        </h2>
        <p class="text-industrial-300 leading-relaxed">
          PeptideBay uses minimal cookies for:
        </p>
        <ul class="space-y-2 text-industrial-400 mt-4">
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Essential site functionality
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Anonymous analytics (if enabled)
          </li>
        </ul>
        <p class="text-industrial-400 mt-4 text-sm">
          We do not use tracking cookies, advertising cookies, or share data with third parties for advertising purposes.
        </p>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Third-Party Services
        </h2>
        <p class="text-industrial-300 leading-relaxed">
          We may use the following third-party services:
        </p>
        <ul class="space-y-2 text-industrial-400 mt-4">
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            <span><strong class="text-industrial-200">Google Fonts</strong> - For typography</span>
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            <span><strong class="text-industrial-200">Analytics</strong> - Anonymous traffic analysis (if applicable)</span>
          </li>
        </ul>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Data Security
        </h2>
        <p class="text-industrial-300 leading-relaxed">
          We implement appropriate security measures to protect any information we collect. However, no method of transmission over the internet is 100% secure.
        </p>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Your Rights
        </h2>
        <p class="text-industrial-300 leading-relaxed mb-4">
          You have the right to:
        </p>
        <ul class="space-y-2 text-industrial-400">
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Request information about data we hold about you
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Request deletion of your personal data
          </li>
          <li class="flex items-center gap-2">
            <span class="text-chem-green">•</span>
            Opt-out of analytics tracking
          </li>
        </ul>
      </div>

      <div class="industrial-panel">
        <h2 class="font-heading text-xl font-bold text-industrial-100 mb-4">
          Contact Us
        </h2>
        <p class="text-industrial-300 leading-relaxed">
          For privacy-related inquiries, contact us at:
        </p>
        <a href="mailto:privacy@peptidebay.shop" class="inline-block mt-4 btn-lab">
          privacy@peptidebay.shop
        </a>
      </div>

    </div>

  </div>
</section>

</BaseLayout>
