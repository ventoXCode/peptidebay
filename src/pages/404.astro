---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Not Found" description="Page not found">

<section class="min-h-[60vh] flex items-center justify-center py-20">
  <div class="max-w-lg mx-auto px-4 text-center">
    
    <!-- 404 as periodic element -->
    <div class="inline-block mb-8">
      <div class="element-card p-8 animate-glow-pulse">
        <div class="text-xs text-chem-red font-mono mb-2">ERROR</div>
        <div class="text-6xl sm:text-7xl font-substance font-bold text-chem-red">
          404
        </div>
        <div class="text-sm text-industrial-300 mt-2">Not Found</div>
      </div>
    </div>
    
    <h1 class="font-heading text-2xl sm:text-3xl font-bold text-industrial-100 mb-4">
      Compound Not Synthesized
    </h1>
    
    <p class="text-industrial-400 mb-8">
      The compound you're looking for doesn't exist in our database, or has been moved to a different location.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/" class="btn-lab">
        Return to Lab
      </a>
      <a href="/database" class="btn-lab">
        Browse Compounds
      </a>
    </div>
    
    <!-- Decorative molecular structure -->
    <div class="mt-16 opacity-20">
      <svg class="w-48 h-48 mx-auto text-chem-green" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.5">
        <circle cx="50" cy="20" r="8" />
        <circle cx="30" cy="50" r="8" />
        <circle cx="70" cy="50" r="8" />
        <circle cx="40" cy="80" r="8" />
        <circle cx="60" cy="80" r="8" />
        <line x1="50" y1="28" x2="35" y2="44" />
        <line x1="50" y1="28" x2="65" y2="44" />
        <line x1="30" y1="58" x2="38" y2="74" />
        <line x1="70" y1="58" x2="62" y2="74" />
        <line x1="48" y1="80" x2="52" y2="80" />
      </svg>
    </div>
    
  </div>
</section>

</BaseLayout>
