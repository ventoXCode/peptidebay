---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn about PeptideBay - your comprehensive resource for peptide and research compound information.">

<section class="py-12 lg:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <header class="text-center mb-12">
      <div class="inline-flex items-center justify-center mb-6">
        <div class="element-card w-24 h-24 flex flex-col items-center justify-center">
          <span class="text-xs text-industrial-400 font-mono">?</span>
          <span class="text-3xl font-substance font-bold text-chem-green">Pb</span>
          <span class="text-xs text-industrial-300">Info</span>
        </div>
      </div>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-industrial-100 mb-4">
        About <span class="text-chem-green">PeptideBay</span>
      </h1>
      <p class="text-xl text-industrial-400">
        Your comprehensive research compound database
      </p>
    </header>

    <!-- Mission -->
    <div class="industrial-panel mb-8">
      <h2 class="font-heading text-2xl font-bold text-industrial-100 mb-4">
        <span class="text-chem-green">Our Mission</span>
      </h2>
      <p class="text-industrial-300 leading-relaxed mb-4">
        PeptideBay provides accessible, research-grade information about peptides, nootropics, supplements, and other research compounds. We aggregate peer-reviewed studies, dosing protocols, and real-world user experiences into comprehensive compound profiles.
      </p>
      <p class="text-industrial-300 leading-relaxed">
        Our goal is to be the most complete and reliable resource for researchers, biohackers, and health enthusiasts seeking accurate compound information.
      </p>
    </div>

    <!-- What We Offer -->
    <div class="industrial-panel mb-8">
      <h2 class="font-heading text-2xl font-bold text-industrial-100 mb-4">
        <span class="text-chem-green">What We Offer</span>
      </h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <h3 class="font-heading font-semibold text-chem-green mb-2">🔬 Compound Database</h3>
          <p class="text-industrial-400 text-sm">
            506+ compounds with detailed profiles including peptides, nootropics, supplements, SARMs, and more.
          </p>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-chem-cyan mb-2">📚 Research Studies</h3>
          <p class="text-industrial-400 text-sm">
            Peer-reviewed research citations and summaries from PubMed and other scientific sources.
          </p>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-chem-amber mb-2">💉 Dosing Protocols</h3>
          <p class="text-industrial-400 text-sm">
            Community-reported dosing guidelines and administration methods.
          </p>
        </div>
        <div>
          <h3 class="font-heading font-semibold text-industrial-300 mb-2">👥 User Experiences</h3>
          <p class="text-industrial-400 text-sm">
            Aggregated sentiment analysis from real-world usage reports.
          </p>
        </div>
      </div>
    </div>

    <!-- Data Sources -->
    <div class="industrial-panel mb-8">
      <h2 class="font-heading text-2xl font-bold text-industrial-100 mb-4">
        <span class="text-chem-green">Data Sources</span>
      </h2>
      <p class="text-industrial-300 leading-relaxed mb-4">
        Our compound data is aggregated from publicly available research databases and community resources:
      </p>
      <ul class="space-y-2 text-industrial-400">
        <li class="flex items-center gap-2">
          <span class="text-chem-green">•</span>
          PubMed / NCBI research publications
        </li>
        <li class="flex items-center gap-2">
          <span class="text-chem-green">•</span>
          Community-reported experiences and protocols
        </li>
        <li class="flex items-center gap-2">
          <span class="text-chem-green">•</span>
          Scientific journals and clinical studies
        </li>
      </ul>
    </div>

    <!-- Disclaimer -->
    <div class="industrial-panel border-l-4 border-l-chem-red">
      <h2 class="font-heading text-2xl font-bold text-chem-red mb-4">
        ⚠️ Important Disclaimer
      </h2>
      <p class="text-industrial-300 leading-relaxed mb-4">
        <strong>The information provided on PeptideBay is for educational and research purposes only.</strong>
      </p>
      <ul class="space-y-2 text-industrial-400 text-sm">
        <li>• This is NOT medical advice</li>
        <li>• Many compounds listed are NOT approved for human use</li>
        <li>• Always consult a qualified healthcare professional</li>
        <li>• We do not guarantee accuracy or completeness of information</li>
        <li>• Use of any compounds is at your own risk</li>
      </ul>
    </div>

    <!-- Contact -->
    <div class="text-center mt-12">
      <p class="text-industrial-400 mb-4">
        Questions or suggestions? We'd love to hear from you.
      </p>
      <a href="mailto:hello@peptidebay.shop" class="btn-lab inline-block">
        Contact Us
      </a>
    </div>

  </div>
</section>

</BaseLayout>
